# Manalog — environment variables. Copy to `.env` and edit. Never commit .env.

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mtgo:changeme@db/mtgo_tracker
DB_PASSWORD=changeme

# ── App ───────────────────────────────────────────────────────────────────
SECRET_KEY=changeme
# Comma-separated origin list. Empty = CORS middleware disabled.
CORS_ORIGINS=

# ── Initial admin user (bootstrap) ────────────────────────────────────────
# When the users table is empty on startup, the app seeds a single user
# from these variables. Leave blank to skip (first agent register will
# then return 401 until a user is created another way). Safe to remove
# from .env after the first boot — bootstrap is a no-op on subsequent
# startups because the table is no longer empty.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@localhost

# ── TLS (Caddy reverse proxy) ─────────────────────────────────────────────
# Mode: off | manual | auto
#   off     — HTTP only. Dev/test. Never production.
#   manual  — Drop cert.pem + key.pem into the manalog-certs volume at
#             /certs/cert.pem and /certs/key.pem. Used for internal CA.
#   auto    — Let's Encrypt via ACME. Requires TLS_DOMAIN and ports
#             80 + 443 reachable from the internet.
TLS_MODE=off
TLS_DOMAIN=

# Published ports for Caddy. Defaults to 80/443; override for lab
# deployments that can't bind privileged ports (e.g. 8080/8443).
HTTP_PORT=80
HTTPS_PORT=443

# ── External data sources ─────────────────────────────────────────────────
TOPDECK_API_KEY=
