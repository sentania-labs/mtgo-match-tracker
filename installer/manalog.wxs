<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Manalog"
    Manufacturer="Sentania Labs"
    Version="!(bind.fileVersion.ManalogExe)"
    UpgradeCode="856f107e-016f-40a4-8dbe-e7e59232a773"
    Scope="perMachine">

    <MajorUpgrade
      AllowSameVersionUpgrades="yes"
      DowngradeErrorMessage="A newer version of Manalog is already installed."
      Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" />

    <Icon Id="rainbow_pentagon.ico" SourceFile="$(var.SourceDir)\..\agent\icons\rainbow_pentagon.ico" />
    <Property Id="ARPPRODUCTICON" Value="rainbow_pentagon.ico" />

    <!-- Install dir -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Manalog" />
    </StandardDirectory>

    <!-- ProgramData scaffold (preserved on uninstall) -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="PROGRAMDATAFOLDER" Name="Manalog" />
    </StandardDirectory>

    <!-- Startup shortcut dir — resolves to
         %APPDATA%\Microsoft\Windows\Start Menu\Programs\Startup -->
    <StandardDirectory Id="StartupFolder" />

    <!-- Start Menu program folder — Manalog subfolder -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ManalogMenuFolder" Name="Manalog" />
    </StandardDirectory>

    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="ManalogExe" Guid="efbd6886-dd05-4b27-9771-b0bdf60e2e76">
        <File Id="ManalogExe" Source="$(var.SourceDir)\Manalog.exe" KeyPath="yes" />
        <RegistryValue
          Root="HKLM"
          Key="SOFTWARE\Manalog"
          Name="InstallDir"
          Type="string"
          Value="[INSTALLFOLDER]" />
        <Shortcut
          Id="StartupShortcut"
          Directory="StartupFolder"
          Name="Manalog"
          Target="[INSTALLFOLDER]Manalog.exe"
          WorkingDirectory="INSTALLFOLDER" />
      </Component>
      <Component Id="ProgramDataDir" Directory="PROGRAMDATAFOLDER" Guid="a197b1e6-f535-443c-939a-6141acb81968">
        <CreateFolder />
        <!-- Preserve on uninstall: no RemoveFolder element -->
      </Component>
      <Component Id="StartMenuShortcut" Directory="ManalogMenuFolder" Guid="ec7e7b07-840e-418f-8b8e-8fd8746c8d1b">
        <Shortcut
          Id="StartMenuSC"
          Name="Manalog"
          Target="[INSTALLFOLDER]Manalog.exe"
          WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveManalogMenuFolder" Directory="ManalogMenuFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\Manalog"
          Name="StartMenuInstalled"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="ProductFeature" Title="Manalog" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Package>
</Wix>
